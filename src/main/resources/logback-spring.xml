<configuration scan="true" scanPeriod="30 seconds">

    <springProperty name="SERVICE_NAME" source="spring.application.name" defaultValue="app"/>
    <springProperty name="ENV"          source="spring.profiles.active"    defaultValue="local"/>

    <springProperty name="LOG_LEVEL_ROOT" source="logging.level.root"      defaultValue="WARN"/>
    <springProperty name="LOG_LEVEL_APP"  source="logging.level.com.welvia" defaultValue="DEBUG"/>

    <logger name="org.springframework"         level="WARN"/>
    <logger name="org.springframework.data"    level="WARN"/>
    <logger name="org.springframework.web"     level="WARN"/>
    <logger name="org.hibernate"               level="WARN"/>
    <logger name="org.hibernate.SQL"           level="WARN"/>
    <logger name="org.apache.catalina"         level="WARN"/>
    <logger name="org.apache.coyote"           level="WARN"/>
    <logger name="org.apache.tomcat"           level="WARN"/>
    <logger name="com.zaxxer.hikari"           level="WARN"/>

    <springProfile name="local">
        <appender name="CONSOLE_TEXT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%cyan(%thread)] %yellow(%logger{36}) - %msg%n%ex</pattern>
            </encoder>
        </appender>

        <logger name="com.welvia" level="${LOG_LEVEL_APP}" additivity="false">
            <appender-ref ref="CONSOLE_TEXT"/>
        </logger>
        <root level="${LOG_LEVEL_ROOT}">
            <appender-ref ref="CONSOLE_TEXT"/>
        </root>
    </springProfile>

    <springProfile name="staging,production,dev">
        <appender name="ASYNC_JSON" class="ch.qos.logback.classic.AsyncAppender">
            <discardingThreshold>0</discardingThreshold>
            <queueSize>512</queueSize>
            <appender-ref ref="CONSOLE_JSON"/>
        </appender>

        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp>
                        <fieldName>@timestamp</fieldName>
                        <pattern>yyyy-MM-dd'T'HH:mm:ss.SSSZZ</pattern>
                        <timeZone>UTC</timeZone>
                    </timestamp>
                    <pattern>
                        <pattern>
                            {
                            "service": "${SERVICE_NAME}",
                            "env":     "${ENV}"
                            }
                        </pattern>
                    </pattern>
                    <logLevel>
                        <fieldName>level</fieldName>
                    </logLevel>
                    <loggerName>
                        <fieldName>logger</fieldName>
                        <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
                    </loggerName>
                    <threadName>
                        <fieldName>thread</fieldName>
                    </threadName>
                    <message>
                        <fieldName>message</fieldName>
                    </message>
                    <arguments/>
                    <mdc/>
                    <stackTrace>
                        <fieldName>error</fieldName>
                        <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                            <maxDepthPerThrowable>20</maxDepthPerThrowable>
                            <maxLength>4096</maxLength>
                            <rootCauseFirst>true</rootCauseFirst>
                            <exclude>sun\.reflect\..*</exclude>
                            <exclude>java\.lang\.reflect\..*</exclude>
                            <exclude>org\.springframework\.cglib\..*</exclude>
                        </throwableConverter>
                    </stackTrace>
                </providers>
            </encoder>
        </appender>

        <logger name="com.welvia" level="${LOG_LEVEL_APP}" additivity="false">
            <appender-ref ref="ASYNC_JSON"/>
        </logger>
        <root level="${LOG_LEVEL_ROOT}">
            <appender-ref ref="ASYNC_JSON"/>
        </root>
    </springProfile>

</configuration>